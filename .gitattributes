# Path-based git attributes
# https://www.kernel.org/pub/software/scm/git/docs/gitattributes.html

# Keep docs/, configs/, templates/, claude/, plugins/ and examples/ in the
# Composer dist: they ARE the product this package ships. plugins/ holds the
# prompt sources that engineering-kit:install copies into .claude/commands/.
/.github            export-ignore
/.gitattributes     export-ignore
/.gitignore         export-ignore
/phpunit.xml.dist   export-ignore
/tests              export-ignore
/.editorconfig      export-ignore
/testbench.yaml     export-ignore
/phpstan.neon.dist  export-ignore
