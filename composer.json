{
    "name": "scrapkit/engineering-kit",
    "description": "Scrapkit Engineering Standards Kit: single source of truth for coding standards, architecture guidelines, AI-usage guidelines, shared tool configs and process templates",
    "keywords": [
        "scrapkit",
        "laravel",
        "coding-standards",
        "engineering-standards",
        "developer-experience",
        "phpstan",
        "pint",
        "claude"
    ],
    "homepage": "https://github.com/scrapkit/engineering-kit",
    "license": "MIT",
    "authors": [
        {
            "name": "Vincenzo Scozzari",
            "email": "vincenzo.scoz9@gmail.com",
            "homepage": "https://github.com/Scoz9",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3",
        "spatie/laravel-package-tools": "^1.16",
        "illuminate/contracts": "^11.0||^12.0||^13.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.14",
        "nunomaduro/collision": "^8.8",
        "orchestra/testbench": "^11.0.0||^10.0.0||^9.0.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Scrapkit\\EngineeringKit\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Scrapkit\\EngineeringKit\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Scrapkit\\EngineeringKit\\EngineeringKitServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
